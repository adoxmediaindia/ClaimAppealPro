# ==========================================
# ClaimAppealPro Environment Template
# Duplicate this file to .env and supply actual keys.
# ==========================================

# Database
# Target pooler URL. Required for Prisma interactions.
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/<dbname>?schema=public&sslmode=require"

# Supabase Auth
# Core access parameters for JWT validation and client libraries.
NEXT_PUBLIC_SUPABASE_URL="https://<project-id>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<public-anonymous-key>"
SUPABASE_SERVICE_ROLE_KEY="<secret-service-role-key>"

# OpenAI API
# Integration credentials for generating appeal documents.
OPENAI_API_KEY="sk-proj-..."

# Stripe Billing
# Key configs for pricing gates and webhook callbacks.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend Mail
# Credentials for sending notifications and transaction receipt templates.
RESEND_API_KEY="re_..."

# Application Metadata
APP_URL="http://localhost:3000"
NODE_ENV="development" # development, staging, production
