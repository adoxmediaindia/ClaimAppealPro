# Handle line endings automatically for files detected as text
# and leave all files detected as binary untouched.
* text=auto

# Force LF on text files to prevent Windows carriage return differences
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.prisma text eol=lf
*.md text eol=lf
*.yml text eol=lf
